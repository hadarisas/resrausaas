# Supabase — get these from your project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# Service role key — NEVER expose to the client/browser
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# Your deployed URL (used for JSON-LD, Open Graph, etc.)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# --- Brevo SMTP (transactional email) ---
# Dashboard: https://app.brevo.com/ → SMTP & API → SMTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
# Login shown as "SMTP key" user, e.g. xxx@smtp-brevo.com
BREVO_SMTP_USER=
# SMTP key / API key (keep secret; never commit)
BREVO_SMTP_KEY=
# Must be a verified sender in Brevo (Settings → Senders)
BREVO_EMAIL_FROM=noreply@your-verified-domain.com

# Optional: protect POST /api/test-email in production (send header x-email-test-secret)
# EMAIL_TEST_SECRET=random-long-string
